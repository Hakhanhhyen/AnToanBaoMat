<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PETCARE</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <style>
        <style >
        body {
            background-color: #f8f9fa;
        }
        /* Sidebar -  màu xanh biển*/
        .sidebar {
            height: 100vh;
            background: #02647f; 
            color: #ffffff; /* Chữ trắng   */
            position: sticky;
            top: 0;
            overflow-y: auto;
            text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4); 
        }


            .sidebar a {
                color: #ffffff !important; 
                display: block;
                padding: 14px 20px;
                text-decoration: none;
                transition: background 0.3s;
            }

                .sidebar a:hover {
                    background: #004d66; 
                    color: #ffffff !important;
                }
        .navbar-ocean {
            background-color: #02647f !important;
        }

        .text-primary {
            color: #038ca6 !important;
        }

        .bg-primary {
            background-color: #02647f !important;
        }

        .btn-primary {
            background-color: #038ca6 !important;
            border-color: #038ca6 !important;
        }

            .btn-primary:hover {
                background-color: #02647f !important;
                border-color: #02647f !important;
            }

        h1, h2, h3, h4 {
            color: #02647f !important;
        }

        a {
            color: #038ca6 !important;
        }

            a:hover {
                color: #02647f !important;
            }
        /* override màu chữ thành trắng cho các nút chính */
        .btn-success,
        .btn-warning,
        .btn-danger,
        .btn-primary,
        .btn-info,
        .btn-secondary {
            color: #ffffff !important; /* Chữ trắng cho tất cả nút */
        }

        .btn-warning {
            color: #212529 !important; /* Giữ chữ đen cho nút vàng */
           
        }
        .btn-add, .btn.btn-success {
            color: #ffffff !important;
        }

        /* Hover vẫn giữ chữ trắng */
        .btn-success:hover,
        .btn-warning:hover,
        .btn-danger:hover,
        .btn-primary:hover {
            color: #ffffff !important;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark navbar-ocean shadow-sm">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">PETCARE</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    @if (Context.Session.GetString("Role") == null)
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="TaiKhoan" asp-action="Login">Đăng nhập</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="TaiKhoan" asp-action="Register">Đăng ký</a></li>
                    }
                    else
                    {
                        <li class="nav-item"><span class="nav-link text-white">Xin chào, @Context.Session.GetString("TenDangNhap")</span></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="TaiKhoan" asp-action="ChangePassword">Đổi mật khẩu</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="TaiKhoan" asp-action="Logout">Đăng xuất</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            @if (Context.Session.GetString("Role") != null)
            {
                <div class="col-md-2 sidebar pt-3">
                   
                    @if (Context.Session.GetString("Role") == "Admin")
                    {
                        <a asp-controller="QuanTri" asp-action="Dashboard">Dashboard</a>
                        <a asp-controller="ThuCung" asp-action="Index">Quản lý thú cưng</a>
                        <a asp-controller="DichVu" asp-action="Index">Quản lý dịch vụ</a>
                        <a asp-controller="NhanVien" asp-action="Index">Quản lý nhân viên</a>
                        <a asp-controller="LichHen" asp-action="Index">Quản lý lịch hẹn</a>
                        <a asp-controller="HoSoChamSoc" asp-action="Index">Hồ sơ chăm sóc</a>
                    }
                    @if (Context.Session.GetString("Role") == "NhanVien")
                    {
                        <a asp-controller="LichHen" asp-action="Index">Quản lý lịch hẹn</a>
                        <a asp-controller="HoSoChamSoc" asp-action="Index">Cập nhật hồ sơ chăm sóc</a>
                    }
                    @if (Context.Session.GetString("Role") == "KhachHang")
                    {
                        <a asp-controller="ThuCung" asp-action="Index">Thú cưng của tôi</a>
                        <a asp-controller="LichHen" asp-action="Index">Lịch hẹn của tôi</a>
                        <a asp-controller="HoSoChamSoc" asp-action="LichSuChamSoc">Lịch sử chăm sóc</a>
                    }
                    <a asp-controller="TaiKhoan" asp-action="ChangePassword">Đổi mật khẩu</a>
                    <a asp-controller="TaiKhoan" asp-action="Logout">Đăng xuất</a>
                </div>
            }
            <main class="@(Context.Session.GetString("Role") != null ? "col-md-10" : "col-12") p-4">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>