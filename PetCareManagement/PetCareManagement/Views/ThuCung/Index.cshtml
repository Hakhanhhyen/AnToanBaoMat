@model IEnumerable<QuanLyChamSocThuCung.Models.ThuCung>

<h2>Thú cưng của tôi</h2>

<p>
    <a asp-action="Create" class="btn btn-success">Thêm thú cưng mới</a>
</p>

<table class="table table-hover table-striped">
    <thead class="table-dark">
        <tr>
            <th>Tên</th>
            <th>Loài</th>
            <th>Giống</th>
            <th>Tuổi</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.TenThuCung</td>
                <td>@item.Loai</td>
                <td>@item.Giong</td>
                <td>@item.Tuoi</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.ThuCungId" class="btn btn-warning btn-sm">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.ThuCungId" class="btn btn-danger btn-sm" onclick="return confirm('Xác nhận xóa?');">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>