@{
}
<h2>Thống kê dịch vụ</h2>

<table class="table table-bordered">

    <tr>
        <th>Dịch vụ</th>
        <th>Số lần sử dụng</th>
    </tr>

    @foreach (var item in ViewBag.ThongKe)
    {

        <tr>

            <td>@item.DichVu</td>

            <td>@item.SoLan</td>

        </tr>

    }

</table>