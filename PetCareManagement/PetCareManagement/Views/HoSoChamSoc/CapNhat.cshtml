@model QuanLyChamSocThuCung.Models.HoSoChamSoc

<h2>Cập nhật hồ sơ chăm sóc</h2>

<form asp-action="CapNhat">

    <input type="hidden" asp-for="ThuCungId" />
    <input type="hidden" asp-for="LichHenId" />

    <div class="form-group">
        <label>Chẩn đoán</label>
        <input asp-for="ChanDoan" class="form-control" />
    </div>

    <div class="form-group">
        <label>Điều trị</label>
        <input asp-for="DieuTri" class="form-control" />
    </div>

    <div class="form-group">
        <label>Ghi chú tình trạng thú cưng</label>
        <input asp-for="GhiChu" class="form-control" />
    </div>

    <br>

    <button type="submit" class="btn btn-success">
        Lưu kết quả khám
    </button>

    <a asp-controller="LichHen"
       asp-action="Index"
       class="btn btn-secondary">
        Quay lại
    </a>

</form>