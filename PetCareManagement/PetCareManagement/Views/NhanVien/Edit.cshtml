@model QuanLyChamSocThuCung.Models.NhanVien

<h2>Sửa nhân viên</h2>

<form asp-action="Edit">

    <input type="hidden" asp-for="NhanVienId" />

    <div class="form-group">
        <label>Tên nhân viên</label>
        <input asp-for="TenNhanVien" class="form-control" />
    </div>

    <div class="form-group">
        <label>Điện thoại</label>
        <input asp-for="DienThoai" class="form-control" />
    </div>

    <div class="form-group">
        <label>Chức vụ</label>
        <input asp-for="ChucVu" class="form-control" />
    </div>

    <br />

    <button type="submit" class="btn btn-primary">
        Cập nhật
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Quay lại
    </a>

</form>