@model QuanLyChamSocThuCung.Models.ThuCung

<h2>Thêm thú cưng</h2>

<form asp-action="Create">

    <div class="form-group">
        <label>Tên thú cưng</label>
        <input asp-for="TenThuCung" class="form-control" />
    </div>

    <div class="form-group">
        <label>Loài</label>
        <input asp-for="Loai" class="form-control" />
    </div>

    <div class="form-group">
        <label>Giống</label>
        <input asp-for="Giong" class="form-control" />
    </div>

    <div class="form-group">
        <label>Tuổi</label>
        <input asp-for="Tuoi" class="form-control" />
    </div>

    <div class="form-group">
        <label>Khách hàng</label>
        <input asp-for="KhachHangId" class="form-control" />
    </div>

    <br />

    <button type="submit" class="btn btn-success">Lưu</button>

    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>

</form>