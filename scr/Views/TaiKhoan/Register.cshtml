@{
    ViewData["Title"] = "Đăng ký";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-success text-white text-center">
                    <h4>Đăng ký tài khoản PETCARE</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        
                        <div class="mb-3">
                            <label>Tên đăng nhập</label>
                            <input name="TenDangNhap" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label>Số điện thoại</label>
                            <input name="DienThoai" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label>Mật khẩu</label>
                            <input name="MatKhau" type="password" class="form-control" minlength="8" required />
                            <small class="text-muted">Mật khẩu phải có ít nhất 8 ký tự, gồm chữ hoa, chữ thường, số và ký tự đặc biệt. Ví dụ: Manh@123</small>
                        </div>
                        <div class="mb-3">
                            <label>Vai trò</label>
                            <select name="VaiTro" class="form-control" required>
                                <option value="KhachHang">Khách hàng</option>
                                <option value="NhanVien">Nhân viên</option>
                                <option value="Admin">Admin</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-success w-100">Đăng ký</button>

                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger mt-3">@ViewBag.Error</div>
                        }
                    </form>
                    <p class="text-center mt-3">
                        Đã có tài khoản? <a href="@Url.Action("Login")">Đăng nhập</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>