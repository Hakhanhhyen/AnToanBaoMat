@model IEnumerable<QuanLyChamSocThuCung.Models.NhanVien>

<h2>Quản lý nhân viên</h2>

<a asp-action="Create" class="btn btn-success mb-3">
    Thêm nhân viên
</a>

<table class="table table-striped">

    <thead>
        <tr>
            <th>Tên nhân viên</th>
            <th>Điện thoại</th>
            <th>Chức vụ</th>
            <th>Thao tác</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.TenNhanVien</td>
                <td>@item.DienThoai</td>
                <td>@item.ChucVu</td>

                <td>

                    <a asp-action="Edit" asp-route-id="@item.NhanVienId"
                       class="btn btn-warning btn-sm">
                        Sửa
                    </a>

                    <a asp-action="Delete" asp-route-id="@item.NhanVienId"
                       class="btn btn-danger btn-sm">
                        Xóa
                    </a>

                </td>
            </tr>
        }

    </tbody>

</table>